{
  "name": "batchtrack-om",
  "version": "1.0.2",
  "description": "Batch number generator and tracker for Om International",
  "main": "main.js",
  "author": "Om International",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.ominternational.batchtrack",
    "productName": "BatchTrack",
    "files": [
      "index.html",
      "main.js",
      "icon.png"
    ],
    "publish": {
      "provider": "github",
      "owner": "davidraketic45-rgb",
      "repo": "batchtrack-om"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BatchTrack"
    }
  }
}
